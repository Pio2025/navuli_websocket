# Copy this file to .env and fill in your values

# Must match CHAT_JWT_SECRET in your CodeIgniter .env file
JWT_SECRET=replace-with-a-long-random-secret

# Your CodeIgniter app's base URL (used for CORS)
# In production use your actual domain e.g. https://navulifiji.com
APP_URL=http://localhost

# Port the Socket.IO server listens on (Render sets this automatically)
PORT=3000
